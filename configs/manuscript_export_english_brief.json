  },
  "main_document": {
    "include_sections": {
      "title": true,
      "methods": true,
      "cohort_summary": true,
      "prediction_time_delta": true,
      "feature_group_ablation": false,
      "selected_feature_sets": false,
      "ed_los_sensitivity": true,
      "threshold_analysis": true,
      "decision_curve": true,
      "subgroup_performance": true,
      "next_writing_suggestions": true
    }
  },
  "supplement": {
    "include_tables": ["S1", "S2", "S6", "S7", "S8", "S9", "S10"],
    "max_rows": {
      "S10": 40
    }
  }
}
