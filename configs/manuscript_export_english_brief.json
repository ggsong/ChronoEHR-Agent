{
  "language": "en",
  "status": "scaffold_only",
  "description": "English brief manuscript preset scaffold. The current DOCX exporter is still Chinese-first, so this preset is discoverable but not recommended for final English export until English body-text templates are implemented.",
  "outputs": {
    "main_docx": "outputs/reports/ChronoEHR_Methods_Results_English_Brief.docx",
